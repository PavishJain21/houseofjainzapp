{
  "expo": {
    "name": "House of Jainz",
    "slug": "house-of-jainz",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.houseofjainz.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4CAF50"
      },
      "package": "com.houseofjainz.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow House of Jainz to use your location to find nearby shops and community posts."
        }
      ],
      "expo-web-browser"
    ],
    "web": {
      "bundler": "metro",
      "name": "House of Jainz",
      "shortName": "House of Jainz",
      "description": "Community, Forum, Marketplace and more"
    },
    "scheme": "houseofjainz",
    "extra": {
      "eas": {
        "projectId": "25136b03-a39b-4ae1-a43e-b9ae3183cbb5"
      }
    }
  }
}
